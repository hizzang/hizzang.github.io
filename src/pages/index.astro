---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredProjects = site.projects.filter((project) => project.featured);
const getPostUrl = (post) => `/blog/${post.id.replace(/\.md$/, '')}/`;
---
<BaseLayout>
  <section class="brand-hero">
    <div class="brand-hero-bg"></div>
    <div class="container brand-hero-inner">
      <div class="hero-content">
        <p class="eyebrow">{site.tagline}</p>
        <h1>
          플랫폼을 설계하고,<br />
          <span class="text-accent">경험을 기록</span>합니다.
        </h1>
        <p class="lead">{site.bio}</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/about/">About Me</a>
          <a class="btn btn-secondary" href="/blog/">Read Blog</a>
          <a class="btn btn-ghost" href={site.social.github} rel="me">GitHub</a>
        </div>
      </div>
      <div class="profile-card">
        <div class="profile-avatar">{site.name.charAt(0)}</div>
        <div class="profile-info">
          <strong>{site.name}</strong>
          <span>{site.role}</span>
          <span class="profile-location">{site.location}</span>
        </div>
        <div class="profile-highlights">
          {site.highlights.map((item) => (
            <div class="highlight-item">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="section-header">
      <p class="eyebrow">Expertise</p>
      <h2>전문 영역</h2>
      <p class="section-desc">게임 플랫폼부터 인프라, 자동화까지 — 운영과 개발을 연결하는 영역을 다룹니다.</p>
    </div>
    <div class="grid expertise-grid">
      {site.expertise.map((item) => (
        <div class="card expertise-card">
          <span class="expertise-icon">{item.icon}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="section-header row">
      <div>
        <p class="eyebrow">Projects</p>
        <h2>주요 프로젝트</h2>
      </div>
      <a class="text-link" href="/projects/">전체 보기 →</a>
    </div>
    <div class="grid project-grid">
      {featuredProjects.map((project) => (
        <a class="card project-card" href={project.href}>
          <p class="project-category">{project.category}</p>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="tags">
            {project.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="section-header row">
      <div>
        <p class="eyebrow">Latest Posts</p>
        <h2>최근 글</h2>
      </div>
      <a class="text-link" href="/blog/">전체 글 →</a>
    </div>
    <div class="post-list">
      {posts.map((post) => (
        <article class="post-card">
          <p class="post-meta">{post.data.pubDate.toLocaleDateString('ko-KR')} · {post.data.tags.join(' · ')}</p>
          <h3><a href={getPostUrl(post)}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="tags">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
        </article>
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="cta-panel">
      <div>
        <p class="eyebrow">Connect</p>
        <h2>함께 일하고, 배우고, 기록합니다.</h2>
        <p class="cta-desc">
          플랫폼 엔지니어링, 인프라 설계, 운영 자동화에 관심이 있다면 GitHub에서 더 많은 프로젝트와 코드를 확인할 수 있습니다.
        </p>
      </div>
      <div class="cta-actions">
        <a class="btn btn-primary" href={site.social.github} rel="me">GitHub 방문</a>
        <a class="btn btn-secondary" href="/about/">About</a>
      </div>
    </div>
  </section>
</BaseLayout>
