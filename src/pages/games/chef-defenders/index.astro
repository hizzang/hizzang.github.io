---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const notices = [
  { type: 'Update', title: '시즌 1 사전등록 준비 중', date: '2026.07.02' },
  { type: 'Event', title: '런칭 기념 보상 이벤트 예고', date: '2026.07.08' },
  { type: 'Notice', title: '공식 커뮤니티 오픈 예정', date: '2026.07.15' }
];

const features = [
  '전략형 디펜스 전투',
  '요리사 히어로 수집',
  '스테이지별 보스 공략',
  '시즌 이벤트와 랭킹 경쟁'
];
---
<BaseLayout
  title="Chef Defenders | Brand Site Sample"
  description="Astro로 만든 게임 브랜드 사이트 샘플 페이지입니다."
>
  <section class="brand-hero game-brand-page">
    <div class="floating-orb orb-a"></div>
    <div class="floating-orb orb-b"></div>
    <div class="brand-hero-inner">
      <div class="brand-copy">
        <p class="brand-kicker">ASTRO GAME BRAND SITE SAMPLE</p>
        <h1>Chef Defenders</h1>
        <p class="brand-lead">
          요리사 히어로들이 몬스터의 습격으로부터 왕국의 주방을 지키는
          캐주얼 전략 디펜스 게임 브랜드 사이트 샘플입니다.
        </p>
        <div class="brand-actions" id="cta-area">
          <a class="primary-cta" href="https://example.com/pre-register">사전등록</a>
          <a class="secondary-cta" href="#notice">공지 보기</a>
        </div>
        <p class="api-hint">CTA와 공지는 실제 서비스에서는 외부 API 응답으로 교체하는 구조를 가정합니다.</p>
      </div>

      <div class="hero-stage" aria-label="Chef Defenders visual sample">
        <div class="chef-card main-chef">
          <span class="chef-icon">🍳</span>
          <strong>Master Chef</strong>
          <small>Fire Pan Strike</small>
        </div>
        <div class="chef-card side-chef side-a">
          <span class="chef-icon">🥘</span>
          <strong>Soup Mage</strong>
        </div>
        <div class="chef-card side-chef side-b">
          <span class="chef-icon">🥐</span>
          <strong>Baker Guard</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="container brand-section">
    <p class="eyebrow">Game Features</p>
    <h2>브랜드 사이트 구성 예시</h2>
    <div class="brand-feature-grid">
      {features.map((feature) => (
        <article class="brand-feature-card">
          <span class="feature-dot"></span>
          <h3>{feature}</h3>
          <p>이미지는 CDN, CTA/공지/이벤트 배너는 외부 API로 교체 가능한 카드 구조입니다.</p>
        </article>
      ))}
    </div>
  </section>

  <section id="notice" class="container brand-section">
    <p class="eyebrow">External Notice API Mock</p>
    <h2>공지 영역</h2>
    <div class="notice-panel">
      {notices.map((notice) => (
        <article class="notice-row">
          <span>{notice.type}</span>
          <strong>{notice.title}</strong>
          <time>{notice.date}</time>
        </article>
      ))}
    </div>
  </section>

  <section class="container brand-section cdn-section">
    <div>
      <p class="eyebrow">CDN Asset Area</p>
      <h2>이미지/CDN 배치 예시</h2>
      <p>
        실제 운영에서는 배경 이미지, 캐릭터 이미지, Lottie JSON, 영상 파일을 CDN에 올리고
        이 영역에서는 CDN URL만 참조하면 됩니다.
      </p>
    </div>
    <div class="cdn-placeholder">
      <span>CDN IMAGE</span>
    </div>
  </section>
</BaseLayout>

<script>
  const ctaArea = document.querySelector('#cta-area');

  async function loadCtaSample() {
    // 실제 운영 예시:
    // const response = await fetch('https://api.example.com/games/chef-defenders/cta');
    // const cta = await response.json();
    // ctaArea.querySelector('.primary-cta').textContent = cta.label;
    // ctaArea.querySelector('.primary-cta').setAttribute('href', cta.url);
  }

  loadCtaSample();
</script>
