---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const notices = [
  { type: 'UPDATE', title: '시즌 1 사전등록 캠페인 공개', date: '2026.07.02' },
  { type: 'EVENT', title: '런칭 보상: 전설 팬과 루비 3,000개 지급', date: '2026.07.08' },
  { type: 'NOTICE', title: '공식 커뮤니티 및 Discord 오픈 예정', date: '2026.07.15' }
];

const features = [
  { icon: '🔥', title: '스킬 연계 디펜스', text: '팬, 오븐, 소스 마법을 조합해 몰려오는 몬스터를 한 번에 제압합니다.' },
  { icon: '👨‍🍳', title: '개성 있는 셰프 영웅', text: '탱커, 딜러, 서포터 셰프를 수집하고 나만의 주방 방어대를 구성합니다.' },
  { icon: '🏰', title: '왕국 주방 전선', text: '시장, 항구, 왕성 주방까지 이어지는 스테이지를 공략합니다.' },
  { icon: '🏆', title: '시즌 랭킹 경쟁', text: '주간 보스전과 무한 웨이브에서 최고 점수를 기록합니다.' }
];

const characters = [
  { role: 'Fire Dealer', name: 'Pan Master Rio', icon: '🍳', skill: 'Flame Pan Strike' },
  { role: 'Support', name: 'Soup Mage Mina', icon: '🥘', skill: 'Healing Broth' },
  { role: 'Guard', name: 'Baker Guard Tom', icon: '🥐', skill: 'Bread Wall' }
];

const media = ['TRAILER', 'GAME PLAY', 'CHARACTER PV'];
---
<BaseLayout
  title="Chef Defenders | Official Brand Site Sample"
  description="Astro로 만든 게임 공식 브랜드 사이트 샘플 페이지입니다."
>
  <main class="game-official">
    <section class="official-hero">
      <div class="hero-noise"></div>
      <div class="hero-particles">
        <span></span><span></span><span></span><span></span>
      </div>

      <div class="official-hero-inner">
        <div class="official-copy">
          <p class="launch-badge">GLOBAL PRE-REGISTRATION OPEN</p>
          <h1><span>Chef</span> Defenders</h1>
          <p class="official-subtitle">왕국의 마지막 주방을 지켜라</p>
          <p class="official-lead">
            몰려오는 식재료 몬스터를 상대로 셰프 영웅들이 펼치는
            캐주얼 판타지 타워 디펜스. 지금 사전등록하고 런칭 보상을 받으세요.
          </p>
          <div class="store-buttons" id="cta-area">
            <a class="game-primary-cta" href="https://example.com/pre-register">사전등록 하기</a>
            <a class="game-secondary-cta" href="#media">트레일러 보기</a>
          </div>
          <div class="platform-row">
            <span>iOS</span><span>Android</span><span>PC Launcher</span>
          </div>
        </div>

        <div class="key-visual" aria-label="Chef Defenders key visual placeholder">
          <div class="battle-aura"></div>
          <div class="boss monster">👾</div>
          <div class="hero-character hero-main">🍳</div>
          <div class="hero-character hero-left">🥘</div>
          <div class="hero-character hero-right">🥐</div>
          <div class="damage-pop pop-a">CRITICAL!</div>
          <div class="damage-pop pop-b">+3000</div>
        </div>
      </div>
    </section>

    <section class="game-section feature-section">
      <div class="section-title">
        <p>GAME FEATURES</p>
        <h2>쉽게 시작하고, 깊게 파고드는 전략 디펜스</h2>
      </div>
      <div class="game-feature-grid">
        {features.map((feature) => (
          <article class="game-feature-card">
            <span>{feature.icon}</span>
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="game-section story-section">
      <div class="story-panel">
        <p>WORLD VIEW</p>
        <h2>마법 레시피를 노리는 몬스터 군단</h2>
        <p>
          왕국의 비밀 레시피북이 깨어난 날, 식재료 몬스터들이 주방을 습격하기 시작했습니다.
          플레이어는 셰프 지휘관이 되어 주방 라인을 배치하고, 스킬 타이밍으로 전장을 뒤집어야 합니다.
        </p>
      </div>
      <div class="world-map-card">
        <span>WORLD MAP</span>
        <strong>Royal Kitchen Front</strong>
      </div>
    </section>

    <section class="game-section character-section">
      <div class="section-title">
        <p>CHARACTERS</p>
        <h2>셰프 영웅 라인업</h2>
      </div>
      <div class="character-grid">
        {characters.map((character) => (
          <article class="character-card">
            <div class="character-icon">{character.icon}</div>
            <p>{character.role}</p>
            <h3>{character.name}</h3>
            <span>{character.skill}</span>
          </article>
        ))}
      </div>
    </section>

    <section id="media" class="game-section media-section">
      <div class="section-title">
        <p>MEDIA</p>
        <h2>트레일러와 플레이 영상</h2>
      </div>
      <div class="media-grid">
        {media.map((item) => (
          <article class="media-card">
            <div class="play-button">▶</div>
            <strong>{item}</strong>
            <span>CDN VIDEO / IMAGE AREA</span>
          </article>
        ))}
      </div>
    </section>

    <section id="notice" class="game-section notice-section">
      <div class="section-title compact">
        <p>NEWS</p>
        <h2>최신 공지</h2>
      </div>
      <div class="game-notice-panel">
        {notices.map((notice) => (
          <article class="game-notice-row">
            <span>{notice.type}</span>
            <strong>{notice.title}</strong>
            <time>{notice.date}</time>
          </article>
        ))}
      </div>
    </section>

    <section class="pre-register-section">
      <div>
        <p>PRE-REGISTRATION REWARD</p>
        <h2>지금 등록하면 런칭 보상 지급</h2>
        <p>전설 팬 장비, 루비 3,000개, 한정 프로필 프레임을 사전등록 유저 전원에게 지급합니다.</p>
      </div>
      <a class="game-primary-cta large" href="https://example.com/pre-register">사전등록 참여</a>
    </section>
  </main>

  <script>
    async function loadCtaSample() {
      // 실제 운영 예시:
      // const response = await fetch('https://api.example.com/games/chef-defenders/cta');
      // const cta = await response.json();
      // document.querySelector('.game-primary-cta').textContent = cta.label;
      // document.querySelector('.game-primary-cta').setAttribute('href', cta.url);
    }

    loadCtaSample();
  </script>
</BaseLayout>
