---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---
<BaseLayout title={`About | ${site.name}`} description={site.longBio}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">About</p>
      <h1>{site.name}</h1>
      <p class="lead">{site.longBio}</p>
    </div>
  </section>

  <section class="container section">
    <div class="about-grid">
      <div class="card about-card">
        <h3>역할</h3>
        <p class="about-role">{site.role}</p>
        <p>{site.bio}</p>
      </div>
      <div class="card about-card">
        <h3>연락처</h3>
        <ul class="about-list">
          <li><span>GitHub</span><a href={site.social.github} rel="me">{site.social.github.replace('https://', '')}</a></li>
          <li><span>Email</span><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><span>Location</span>{site.location}</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="section-header">
      <p class="eyebrow">Values</p>
      <h2>일하는 방식</h2>
    </div>
    <div class="grid values-grid">
      {site.values.map((value) => (
        <div class="card value-card">
          <h3>{value.title}</h3>
          <p>{value.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="section-header">
      <p class="eyebrow">Expertise</p>
      <h2>전문 영역</h2>
    </div>
    <div class="grid expertise-grid">
      {site.expertise.map((item) => (
        <div class="card expertise-card">
          <span class="expertise-icon">{item.icon}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
