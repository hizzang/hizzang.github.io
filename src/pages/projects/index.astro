---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site';
---
<BaseLayout title={`Projects | ${site.name}`} description="hizzang의 프로젝트와 작업물을 소개합니다.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Projects</p>
      <h1>프로젝트</h1>
      <p class="lead">
        플랫폼 엔지니어링, 개인 브랜드 사이트, 게임 브랜드 샘플 등 직접 구축한 프로젝트를 모았습니다.
      </p>
    </div>
  </section>

  <section class="container section">
    <div class="project-list">
      {site.projects.map((project) => (
        <a class="card project-card-large" href={project.href}>
          <div class="project-card-header">
            <p class="project-category">{project.category}</p>
            {project.featured && <span class="tag tag-featured">Featured</span>}
          </div>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="tags">
            {project.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
