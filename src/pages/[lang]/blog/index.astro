---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { site } from '../../../data/site';
import {
  dateLocales,
  getStaticLangPaths,
  getTranslations,
  isLocale,
  localizedPath,
  type Locale
} from '../../../i18n';

export function getStaticPaths() {
  return getStaticLangPaths();
}

const { lang } = Astro.params;
if (!lang || !isLocale(lang)) {
  throw new Error(`Invalid locale: ${lang}`);
}

const locale = lang as Locale;
const t = getTranslations(locale);

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout lang={locale} title={`Blog | ${site.name}`}>
  <section class="container">
    <p class="eyebrow">{t.blog.eyebrow}</p>
    <h1>{t.blog.title}</h1>
    <div class="post-list">
      {posts.map((post) => {
        const slug = post.id.replace('.md', '');
        const url = localizedPath(locale, `/blog/${slug}/`);
        return (
          <article class="post-card">
            <p class="post-meta">{post.data.pubDate.toLocaleDateString(dateLocales[locale])}</p>
            <h3><a href={url}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <div class="tags">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
