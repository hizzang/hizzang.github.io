---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { site } from '../../../data/site';
import { dateLocales, getTranslations, isLocale, locales, localizedPath, type Locale } from '../../../i18n';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

  return locales.flatMap((lang) =>
    posts.map((post) => ({
      params: { lang, slug: post.id.replace('.md', '') },
      props: { post, lang }
    }))
  );
}

type Props = { post: CollectionEntry<'blog'>; lang: Locale };
const { post, lang } = Astro.props;

if (!isLocale(lang)) {
  throw new Error(`Invalid locale: ${lang}`);
}

const t = getTranslations(lang);
const { Content } = await render(post);
---
<BaseLayout lang={lang} title={`${post.data.title} | ${site.name}`} description={post.data.description}>
  <section class="container">
    <article class="article">
      <p class="post-meta">
        {post.data.pubDate.toLocaleDateString(dateLocales[lang])} · {post.data.tags.join(' · ')}
      </p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tags">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
      <Content />
    </article>
    <p class="back-link">
      <a class="text-link" href={localizedPath(lang, '/blog/')}>← {t.blog.title}</a>
    </p>
  </section>
</BaseLayout>

<style>
  .back-link {
    margin-top: 32px;
  }
</style>
