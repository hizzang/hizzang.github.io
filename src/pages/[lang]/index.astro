---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  dateLocales,
  getStaticLangPaths,
  getTranslations,
  isLocale,
  localizeProjectHref,
  localizedPath,
  type Locale
} from '../../i18n';

export function getStaticPaths() {
  return getStaticLangPaths();
}

const { lang } = Astro.params;
if (!lang || !isLocale(lang)) {
  throw new Error(`Invalid locale: ${lang}`);
}

const locale = lang as Locale;
const t = getTranslations(locale);

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredProjects = t.site.projects.filter((project) => project.featured);
const getPostUrl = (slug: string) => localizedPath(locale, `/blog/${slug}/`);
---
<BaseLayout lang={locale}>
  <section class="brand-hero">
    <div class="brand-hero-bg"></div>
    <div class="container brand-hero-inner">
      <div class="hero-content">
        <p class="eyebrow">{t.site.tagline}</p>
        <h1>
          {t.home.heroTitle}<br />
          <span class="text-accent">{t.home.heroTitleAccent}</span>{t.home.heroTitleEnd}
        </h1>
        <p class="lead">{t.site.bio}</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={localizedPath(locale, '/about/')}>{t.home.aboutMe}</a>
          <a class="btn btn-secondary" href={localizedPath(locale, '/blog/')}>{t.home.readBlog}</a>
          <a class="btn btn-ghost" href="https://github.com/hizzang" rel="me">{t.nav.github}</a>
        </div>
      </div>
      <div class="profile-card">
        <div class="profile-avatar">h</div>
        <div class="profile-info">
          <strong>hizzang</strong>
          <span>{t.site.role}</span>
          <span class="profile-location">{t.site.location}</span>
        </div>
        <div class="profile-highlights">
          {t.site.highlights.map((item) => (
            <div class="highlight-item">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="section-header">
      <p class="eyebrow">{t.home.expertiseEyebrow}</p>
      <h2>{t.home.expertiseTitle}</h2>
      <p class="section-desc">{t.home.expertiseDesc}</p>
    </div>
    <div class="grid expertise-grid">
      {t.site.expertise.map((item) => (
        <div class="card expertise-card">
          <span class="expertise-icon">{item.icon}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="section-header row">
      <div>
        <p class="eyebrow">{t.home.projectsEyebrow}</p>
        <h2>{t.home.projectsTitle}</h2>
      </div>
      <a class="text-link" href={localizedPath(locale, '/projects/')}>{t.common.viewAll}</a>
    </div>
    <div class="grid project-grid">
      {featuredProjects.map((project) => (
        <a class="card project-card" href={localizeProjectHref(locale, project.href)}>
          <p class="project-category">{project.category}</p>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="tags">
            {project.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="section-header row">
      <div>
        <p class="eyebrow">{t.home.postsEyebrow}</p>
        <h2>{t.home.postsTitle}</h2>
      </div>
      <a class="text-link" href={localizedPath(locale, '/blog/')}>{t.common.viewAll}</a>
    </div>
    <div class="post-list">
      {posts.map((post) => (
        <article class="post-card">
          <p class="post-meta">
            {post.data.pubDate.toLocaleDateString(dateLocales[locale])} · {post.data.tags.join(' · ')}
          </p>
          <h3>
            <a href={getPostUrl(post.id.replace(/\.md$/, ''))}>{post.data.title}</a>
          </h3>
          <p>{post.data.description}</p>
          <div class="tags">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
        </article>
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="cta-panel">
      <div>
        <p class="eyebrow">{t.home.ctaEyebrow}</p>
        <h2>{t.home.ctaTitle}</h2>
        <p class="cta-desc">{t.home.ctaDesc}</p>
      </div>
      <div class="cta-actions">
        <a class="btn btn-primary" href="https://github.com/hizzang" rel="me">{t.home.visitGithub}</a>
        <a class="btn btn-secondary" href={localizedPath(locale, '/about/')}>{t.common.about}</a>
      </div>
    </div>
  </section>
</BaseLayout>
