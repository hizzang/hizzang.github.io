---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace('.md', '') },
    props: { post }
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} | hizzang blog`} description={post.data.description}>
  <section class="container">
    <article class="article">
      <p class="post-meta">{post.data.pubDate.toLocaleDateString('ko-KR')} · {post.data.tags.join(' · ')}</p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tags">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
      <Content />
    </article>
  </section>
</BaseLayout>
