---
import '../styles/global.css';
import { site } from '../data/site';

const {
  title = site.title,
  description = site.description,
  variant = 'default'
} = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} RSS`} href="/rss.xml" />
    <link rel="me" href={site.social.github} />
  </head>
  <body class={variant === 'game' ? 'page-game' : ''}>
    <header class="site-header">
      <nav class="nav">
        <a class="brand" href="/">
          <span class="brand-mark">h</span>
          <span class="brand-text">{site.name}</span>
        </a>
        <div class="nav-links">
          {site.nav.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
          <a class="nav-cta" href={site.social.github} rel="me">GitHub</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <strong>{site.name}</strong>
          <p>{site.tagline}</p>
        </div>
        <div class="footer-links">
          {site.nav.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
          <a href={site.social.github} rel="me">GitHub</a>
          <a href={site.social.rss}>RSS</a>
        </div>
      </div>
      <p class="footer-copy">© {new Date().getFullYear()} {site.name}. Powered by Astro and GitHub Pages.</p>
    </footer>
  </body>
</html>
