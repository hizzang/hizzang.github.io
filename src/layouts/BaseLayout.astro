---
import '../styles/global.css';

const {
  title = 'hizzang blog',
  description = '개발, 인프라, 게임 플랫폼 운영 기록을 정리하는 개인 기술 블로그입니다.'
} = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="hizzang blog RSS" href="/rss.xml" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav">
        <a class="brand" href="/">hizzang blog</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="/games/chef-defenders/">Games</a>
          <a href="/about/">About</a>
          <a href="/rss.xml">RSS</a>
          <a href="https://github.com/hizzang" rel="me">GitHub</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} hizzang. Powered by Astro and GitHub Pages.</p>
    </footer>
  </body>
</html>
